# ═══════════════════════════════════════════════════════════════════════════════
# dashboard/.env.example — скопируй в .env и заполни
# ═══════════════════════════════════════════════════════════════════════════════

APP_ENV=production           # development | production
APP_HOST=0.0.0.0
APP_PORT=8003
LOG_LEVEL=INFO

# ── MongoDB (те же базы что у Backend) ───────────────────────────────────────
MONGO_USER=ncfu_admin
MONGO_PASSWORD=CHANGE_ME_strong_mongo_password
MONGO_HOST=mongo             # hostname MongoDB (обычно имя сервиса docker)
MONGO_DB=ncfu_schedule
AUTH_MONGO_DB=ncfu_auth

# ── Redis (тот же что у Backend) ─────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_HOST=redis             # hostname Redis

# ── Telegram (нужен для proxy медиа файлов и отправки сообщений) ─────────────
TELEGRAM_BOT_TOKEN=          # основной бот

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Тот же секрет что у Backend и бота — должен совпадать!
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_64
JWT_ALGORITHM=HS256

# ── Dashboard secret (URL-параметр для bootstrap токена) ─────────────────────
# Используется ТОЛЬКО для первого входа через ?secret=... URL
# Основная защита — JWT + RBAC
DASHBOARD_SECRET=CHANGE_ME_openssl_rand_hex_32
ADMIN_PATH=admin             # /admin — секретный путь к дашборду (опционально)

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://dashboard.yourdomain.com

# ── Static files ──────────────────────────────────────────────────────────────
STATIC_DIR=/app/static

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
OTEL_ENDPOINT=

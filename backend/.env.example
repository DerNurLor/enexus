# backend/.env.example — для standalone запуска backend
APP_ENV=production
MONGO_USER=ncfu_admin
MONGO_PASSWORD=CHANGE_ME
MONGO_DB=ncfu_schedule
AUTH_MONGO_DB=ncfu_auth
REDIS_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_64
DASHBOARD_SECRET=CHANGE_ME
ADMIN_PATH=admin
GRAPHQL_SECRET=CHANGE_ME
CORS_ALLOWED_ORIGINS=https://yourdomain.com
BASE_URL=https://ecampus.ncfu.ru
SCRAPE_INTERVAL_HOURS=1
SENTRY_DSN=
OPENAI_API_KEY=sk-...
# MongoDB/Redis URIs собираются автоматически в docker-compose из USER/PASSWORD выше

# ═══════════════════════════════════════════════════════════════════════════════
# .env.example  —  скопируй в .env и заполни все поля
# Используется всеми тремя сервисами через top-level docker-compose.yml
# ═══════════════════════════════════════════════════════════════════════════════

APP_ENV=production       # development | production

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=ncfu_admin
MONGO_PASSWORD=CHANGE_ME_strong_mongo_password
MONGO_DB=ncfu_schedule
AUTH_MONGO_DB=ncfu_auth

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # основной бот (ecampus_bot)
TELEGRAM_WEBHOOK_SECRET=    # openssl rand -hex 32
WEBHOOK_BASE_URL=https://yourdomain.com   # домен где слушает бот (:8001)

SUPPORT_BOT_TOKEN=          # бот поддержки (опционально)
SUPPORT_ADMIN_CHAT_ID=0
ADMIN_BOT_TOKEN=            # бот-администратор (опционально)

# ── OpenAI (ecampus_bot) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Один секрет на все сервисы — должен быть одинаковым везде!
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_64

# ── Dashboard (backend) ───────────────────────────────────────────────────────
DASHBOARD_SECRET=CHANGE_ME
ADMIN_PATH=admin            # /admin — путь к дашборду
GRAPHQL_SECRET=CHANGE_ME    # X-Admin-Secret для GraphQL IDE

# ── CORS (production) ─────────────────────────────────────────────────────────
# Домены через запятую, без пробелов
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://miniapp.yourdomain.com

# ── Scraper (backend) ─────────────────────────────────────────────────────────
BASE_URL=https://ecampus.ncfu.ru
SCRAPER_CONCURRENCY=5
SCRAPE_INTERVAL_HOURS=1

# ── Observability (опционально) ───────────────────────────────────────────────
SENTRY_DSN=
OTEL_ENDPOINT=

# ── Mongo Express (dev profile only) ─────────────────────────────────────────
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=CHANGE_ME_mongo_express_password

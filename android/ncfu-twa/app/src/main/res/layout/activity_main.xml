<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <!-- WebView — основной контент -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        android:background="#0a0a0a" />

    <!-- Splash overlay -->
    <FrameLayout
        android:id="@+id/splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0a0a0a">

        <!-- Логотип и название по центру -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="eNexus" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="eNexus"
                android:textColor="#5ce1e6"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Расписание НЦФУ"
                android:textColor="#8e8e93"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Индикатор загрузки внизу -->
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="100dp"
            android:indeterminateTint="#5ce1e6" />

        <!-- Подсказка при долгой загрузке — скрыта по умолчанию -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="40dp"
            android:layout_marginHorizontal="32dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/splash_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:alpha="0"
                android:text="Загрузка занимает больше обычного...\nПроверьте подключение к интернету"
                android:textColor="#636366"
                android:textSize="13sp"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

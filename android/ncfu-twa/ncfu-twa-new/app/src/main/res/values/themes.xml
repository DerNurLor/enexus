<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Основная тема приложения -->
    <style name="Theme.NCFU" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">#0a0a0a</item>
        <item name="android:navigationBarColor">#0a0a0a</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Тема сплэш-экрана — показывается пока грузится WebView -->
    <style name="Theme.NCFU.Splash" parent="Theme.NCFU">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>

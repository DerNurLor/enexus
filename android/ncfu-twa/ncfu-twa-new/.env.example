# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# ── Подпись APK ───────────────────────────────────────────────────────────────
# Пароль от keystore-файла ncfu.keystore (создаётся командой keytool)
KEYSTORE_PASSWORD=твой_пароль_от_keystore

# Пароль от конкретного ключа внутри keystore (alias: ncfu)
KEY_PASSWORD=твой_пароль_от_ключа

# ── Android SDK ───────────────────────────────────────────────────────────────
# Путь к установленному Android SDK
# Linux:   /home/ИМЯ_ПОЛЬЗОВАТЕЛЯ/android-sdk  или  /opt/android-sdk
# macOS:   /Users/ИМЯ_ПОЛЬЗОВАТЕЛЯ/Library/Android/sdk
# Windows: C:/Users/ИМЯ_ПОЛЬЗОВАТЕЛЯ/AppData/Local/Android/Sdk
ANDROID_HOME=/home/archlinux/android-sdk

# ── Push-уведомления (Firebase Cloud Messaging) ───────────────────────────────
# Получи в Firebase Console → Project Settings → Cloud Messaging
# https://console.firebase.google.com/
# После создания проекта скачай google-services.json и положи в app/
FIREBASE_PROJECT_ID=твой-проект-id

# ── Приложение ────────────────────────────────────────────────────────────────
# URL сайта, который открывается в WebView
APP_URL=https://app.enexus.isabelline.xyz/schedule
